@model POOC.Models.AccountingIndexViewModel
@{
    ViewData["Title"] = "เอกสารและบัญชี";
}

<style>
    /* ── Tabs ── */
    .db-tabs        { display:flex; gap:2px; border-bottom:1px solid #e5e7eb; margin-bottom:1.5rem; }
    .db-tab         { padding:8px 16px; font-size:14px; color:#6b7280; text-decoration:none; border-bottom:2px solid transparent; margin-bottom:-1px; transition:color .15s; }
    .db-tab.active  { color:#111827; border-bottom-color:#111827; font-weight:500; }
    .db-tab:hover   { color:#111827; text-decoration:none; }

    /* ── Header ── */
    .db-header   { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:1.5rem; }
    .db-title    { font-size:22px; font-weight:500; color:#111827; margin:0 0 4px; }
    .db-subtitle { font-size:13px; color:#6b7280; margin:0; }
    .db-badge    { font-size:11px; background:#f9fafb; border:0.5px solid #e5e7eb; border-radius:20px; padding:4px 10px; color:#6b7280; white-space:nowrap; }

    /* ── Filter bar ── */
    .filter-bar  { display:flex; align-items:flex-end; gap:12px; flex-wrap:wrap; background:#f9fafb; border:0.5px solid #e5e7eb; border-radius:12px; padding:14px 16px; margin-bottom:20px; }
    .filter-bar label { font-size:12px; color:#6b7280; font-weight:600; display:block; margin-bottom:4px; }
    .filter-bar input { border:1px solid #d1d5db; border-radius:8px; padding:7px 10px; font-size:13px; background:#fff; }
    .btn-filter  { border:0; border-radius:8px; padding:8px 16px; background:#185FA5; color:#fff; font-size:13px; font-weight:600; cursor:pointer; display:inline-flex; align-items:center; gap:5px; }
    .btn-filter:hover { background:#0C447C; }
    .btn-export  { border:0.5px solid #d1d5db; border-radius:8px; padding:8px 14px; background:#fff; color:#374151; font-size:13px; font-weight:500; cursor:pointer; display:inline-flex; align-items:center; gap:5px; text-decoration:none; }
    .btn-export:hover { background:#f3f4f6; color:#374151; text-decoration:none; }

    /* ── KPI strip ── */
    .kpi-grid      { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:20px; }
    .kpi-card      { background:#fff; border:0.5px solid #e5e7eb; border-radius:10px; padding:14px 16px; }
    .kpi-label     { font-size:12px; color:#6b7280; margin-bottom:6px; display:flex; align-items:center; gap:5px; }
    .kpi-value     { font-size:20px; font-weight:600; color:#111827; }
    .kpi-value.pos { color:#059669; }
    .kpi-value.neg { color:#dc2626; }
    .kpi-value.pri { color:#185FA5; }
    .kpi-value.war { color:#b45309; }
    .kpi-chip      { font-size:10px; margin-top:4px; color:#9ca3af; }

    /* ── Annual interest section ── */
    .interest-section { background:#fff; border:0.5px solid #e5e7eb; border-radius:12px; overflow:hidden; margin-bottom:24px; }
    .interest-section-head { display:flex; justify-content:space-between; align-items:center; padding:14px 16px; border-bottom:0.5px solid #f3f4f6; }
    .interest-section-head h2 { margin:0; font-size:15px; font-weight:600; color:#111827; }
    .interest-form-row { display:flex; align-items:flex-end; gap:12px; flex-wrap:wrap; padding:16px 16px 0; }
    .int-field { display:flex; flex-direction:column; gap:4px; }
    .int-field label { font-size:12px; color:#6b7280; }
    .int-field input { border:1px solid #d1d5db; border-radius:8px; padding:7px 10px; font-size:13px; background:#fff; width:130px; }
    .btn-calc { border:0; border-radius:8px; padding:8px 18px; background:#185FA5; color:#fff; font-size:13px; font-weight:500; cursor:pointer; display:inline-flex; align-items:center; gap:6px; }
    .btn-calc:hover { background:#0C447C; }
    .int-note { font-size:12px; color:#9ca3af; align-self:center; }
    .interest-history { padding:16px; }
    .interest-history-title { font-size:12px; color:#6b7280; margin-bottom:8px; }

    /* ── Main area ── */
    .main-grid   { display:grid; grid-template-columns:1fr 320px; gap:16px; align-items:start; }

    /* ── Card wrapper ── */
    .acc-card    { background:#fff; border:0.5px solid #e5e7eb; border-radius:12px; overflow:hidden; }
    .acc-card-head { display:flex; justify-content:space-between; align-items:center; padding:14px 16px; border-bottom:0.5px solid #f3f4f6; }
    .acc-card-head h2 { margin:0; font-size:15px; font-weight:600; color:#111827; }
    .acc-card-body { padding:0; }

    /* ── Ledger table ── */
    .ledger-wrap { overflow-x:auto; }
    .ledger-table { width:100%; border-collapse:collapse; font-size:13px; }
    .ledger-table thead th { background:#f8fafc; color:#6b7280; font-size:11.5px; font-weight:600; padding:10px 12px; text-align:left; border-bottom:0.5px solid #e5e7eb; white-space:nowrap; letter-spacing:.3px; text-transform:uppercase; }
    .ledger-table tbody td { padding:10px 12px; border-bottom:0.5px solid #f3f4f6; vertical-align:middle; }
    .ledger-table tbody tr:last-child td { border-bottom:0; }
    .ledger-table tbody tr:hover td { background:#fafbfc; }
    .ledger-table .text-end { text-align:right; font-variant-numeric:tabular-nums; }
    .type-badge  { display:inline-block; font-size:11px; padding:2px 8px; border-radius:20px; font-weight:500; }
    .type-ฝาก   { background:#f0fdf4; color:#059669; }
    .type-ถอน   { background:#fef2f2; color:#dc2626; }
    .type-กู้    { background:#eff6ff; color:#185FA5; }
    .type-ชำระ  { background:#fefce8; color:#b45309; }
    .type-ดอก   { background:#fdf4ff; color:#7c3aed; }
    .doc-no { font-family:monospace; font-size:12px; color:#6b7280; }
    .debit-val  { color:#dc2626; font-variant-numeric:tabular-nums; }
    .credit-val { color:#059669; font-variant-numeric:tabular-nums; }

    /* ── Doc list sidebar ── */
    .doc-list    { display:flex; flex-direction:column; }
    .doc-item    { padding:12px 16px; border-bottom:0.5px solid #f3f4f6; transition:background .1s; }
    .doc-item:last-child { border-bottom:0; }
    .doc-item:hover { background:#f9fafb; }
    .doc-item-head { display:flex; justify-content:space-between; align-items:flex-start; gap:8px; margin-bottom:3px; }
    .doc-item-no  { font-family:monospace; font-size:11.5px; color:#185FA5; font-weight:600; }
    .doc-item-amt { font-size:13px; font-weight:600; color:#111827; font-variant-numeric:tabular-nums; }
    .doc-item-meta { font-size:11.5px; color:#9ca3af; }
    .doc-item-dl  { margin-top:6px; }
    .btn-dl { font-size:11px; padding:3px 10px; border:0.5px solid #d1d5db; border-radius:6px; background:#f8fafc; color:#374151; text-decoration:none; }
    .btn-dl:hover { background:#e5e7eb; color:#111827; text-decoration:none; }

    /* ── Empty ── */
    .empty-state { color:#9ca3af; text-align:center; padding:32px 16px; font-size:13px; }
    .empty-state i { font-size:28px; display:block; margin-bottom:6px; opacity:.4; }

    @@media (max-width:1100px) { .kpi-grid { grid-template-columns:repeat(2,1fr); } }
    @@media (max-width:900px)  { .main-grid { grid-template-columns:1fr; } }
    @@media (max-width:640px)  { .kpi-grid { grid-template-columns:repeat(2,1fr); } .filter-bar { flex-direction:column; align-items:stretch; } }
</style>

<div class="container mt-4">

    <!-- TABS -->
    <div class="db-tabs">
        <a class="db-tab @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Member" ? "active" : "")"
           asp-controller="Home" asp-action="Member">สมาชิก</a>
        <a class="db-tab @(ViewContext.RouteData.Values["controller"]?.ToString() == "Accounting" ? "active" : "")"
           asp-controller="Accounting" asp-action="Index">เอกสารและบัญชี</a>
        <a class="db-tab @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")"
           asp-controller="Home" asp-action="Dashboard">ภาพรวม</a>
    </div>

    <!-- HEADER -->
    <div class="db-header">
        <div>
            <p class="db-title">เอกสารและบัญชี</p>
            <p class="db-subtitle">สรุปเงินรับ-จ่าย · แยกประเภทบัญชี · ตรวจเอกสาร</p>
        </div>
        <span class="db-badge">
            <i class="bi bi-arrow-clockwise"></i>
            อัปเดต @DateTime.Now.ToString("HH:mm")
        </span>
    </div>

    <!-- FILTER BAR -->
    <form class="filter-bar" method="get" asp-controller="Accounting" asp-action="Index">
        <div>
            <label for="fromDate">วันที่เริ่มต้น</label>
            <input type="date" id="fromDate" name="fromDate"
                   value="@Model.FromDate.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture)" />
        </div>
        <div>
            <label for="toDate">วันที่สิ้นสุด</label>
            <input type="date" id="toDate" name="toDate"
                   value="@Model.ToDate.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture)" />
        </div>
        <button class="btn-filter" type="submit">
            <i class="bi bi-funnel"></i> กรองข้อมูล
        </button>
        <a class="btn-export"
           asp-controller="Accounting" asp-action="ExportCsv"
           asp-route-fromDate="@Model.FromDate.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture)"
           asp-route-toDate="@Model.ToDate.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture)">
            <i class="bi bi-filetype-csv"></i> CSV
        </a>
        <a class="btn-export"
           asp-controller="Accounting" asp-action="ExportPdf"
           asp-route-fromDate="@Model.FromDate.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture)"
           asp-route-toDate="@Model.ToDate.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture)">
            <i class="bi bi-file-earmark-pdf"></i> PDF
        </a>
    </form>

    <!-- KPI ROW 1: เงินรับ/จ่าย/สุทธิ/ลูกหนี้ -->
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-label"><i class="bi bi-arrow-down-circle text-success"></i> เงินรับรวม</div>
            <div class="kpi-value pos">฿@Model.Summary.CashInflow.ToString("N2")</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label"><i class="bi bi-arrow-up-circle text-danger"></i> เงินจ่ายรวม</div>
            <div class="kpi-value neg">฿@Model.Summary.CashOutflow.ToString("N2")</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label"><i class="bi bi-activity"></i> กระแสเงินสดสุทธิ</div>
            <div class="kpi-value @(Model.Summary.NetCashMovement >= 0 ? "pos" : "neg")">
                ฿@Model.Summary.NetCashMovement.ToString("N2")
            </div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label"><i class="bi bi-person-lines-fill" style="color:#185FA5"></i> ลูกหนี้คงเหลือ</div>
            <div class="kpi-value pri">฿@Model.Summary.OutstandingLoanPrincipal.ToString("N2")</div>
        </div>
    </div>

    <!-- KPI ROW 2: รายละเอียดเงินฝาก/เงินกู้ -->
    <div class="kpi-grid" style="margin-bottom:24px;">
        <div class="kpi-card">
            <div class="kpi-label"><i class="bi bi-piggy-bank" style="color:#059669"></i> รับฝากเงิน</div>
            <div class="kpi-value pos">฿@Model.Summary.SavingsDeposits.ToString("N2")</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label"><i class="bi bi-wallet2" style="color:#dc2626"></i> ถอนเงินฝาก</div>
            <div class="kpi-value neg">฿@Model.Summary.SavingsWithdrawals.ToString("N2")</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label"><i class="bi bi-graph-up" style="color:#b45309"></i> ดอกเบี้ยรับจากเงินกู้</div>
            <div class="kpi-value war">฿@Model.Summary.LoanInterestCollected.ToString("N2")</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label"><i class="bi bi-graph-down" style="color:#7c3aed"></i> ดอกเบี้ยเงินฝากที่จ่าย</div>
            <div class="kpi-value" style="color:#7c3aed">฿@Model.Summary.SavingsInterestPaid.ToString("N2")</div>
        </div>
    </div>

    <!-- ANNUAL INTEREST SECTION -->
    <div class="interest-section">
        <div class="interest-section-head">
            <h2><i class="bi bi-calendar-check" style="margin-right:6px;color:#185FA5"></i>จ่ายดอกเบี้ยเงินฝากประจำปี</h2>
        </div>

        <div class="interest-form-row">
            <div class="int-field">
                <label>ปี (พ.ศ.)</label>
                <input type="number" id="interestYear" value="@(DateTime.Now.Year + 543)" />
            </div>
            <div class="int-field">
                <label>อัตราดอกเบี้ย (%/ปี)</label>
                <input type="number" id="interestRate" value="5" step="0.01" />
            </div>
            <button class="btn-calc" onclick="calcInterest()">
                <i class="bi bi-calculator"></i> คำนวณและบันทึก
            </button>
            <span class="int-note">ดำเนินการได้ครั้งเดียวต่อปี</span>
        </div>

        <div class="interest-history">
            @if (Model.InterestHistory.Any())
            {
                <p class="interest-history-title">ประวัติการจ่ายดอกเบี้ย (@Model.InterestHistory.Count ปี)</p>
                <div class="ledger-wrap">
                    <table class="ledger-table">
                        <thead>
                            <tr>
                                <th>ปี (พ.ศ.)</th>
                                <th class="text-end">อัตรา (%)</th>
                                <th class="text-end">ยอดฝากรวม</th>
                                <th class="text-end">ดอกเบี้ยที่จ่าย</th>
                                <th style="text-align:center;">จำนวนสมาชิก</th>
                                <th>วันที่ดำเนินการ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.InterestHistory)
                            {
                                <tr>
                                    <td>@(row.Year + 543)</td>
                                    <td class="text-end">@row.Rate.ToString("N2")</td>
                                    <td class="text-end">฿@row.TotalPrincipal.ToString("N2")</td>
                                    <td class="text-end credit-val">฿@row.TotalInterest.ToString("N2")</td>
                                    <td style="text-align:center;">@row.MemberCount คน</td>
                                    <td>@row.CreatedDate.ToString("dd MMM yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state" style="padding:20px;">
                    <i class="bi bi-calendar-x"></i>
                    ยังไม่มีประวัติการจ่ายดอกเบี้ย
                </div>
            }
        </div>
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-grid">

        <!-- Ledger Table (ซ้าย) -->
        <div class="acc-card">
            <div class="acc-card-head">
                <h2><i class="bi bi-journal-text" style="margin-right:6px;color:#185FA5"></i>สมุดรายวันบัญชี</h2>
                <span style="font-size:12px;color:#9ca3af;">@Model.LedgerRows.Count รายการ</span>
            </div>
            <div class="acc-card-body">
                @if (Model.LedgerRows.Any())
                {
                    <div class="ledger-wrap">
                        <table class="ledger-table">
                            <thead>
                                <tr>
                                    <th>วันที่</th>
                                    <th>เลขที่</th>
                                    <th>ประเภท</th>
                                    <th>สมาชิก</th>
                                    <th>รายละเอียด</th>
                                    <th class="text-end">เดบิต</th>
                                    <th class="text-end">เครดิต</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.LedgerRows)
                                {
                                    var typeCss = row.Type.Contains("ฝาก") && !row.Type.Contains("ถอน") ? "type-ฝาก"
                                                : row.Type.Contains("ถอน") ? "type-ถอน"
                                                : row.Type.Contains("กู้") && !row.Type.Contains("ชำระ") ? "type-กู้"
                                                : row.Type.Contains("ชำระ") ? "type-ชำระ"
                                                : "type-ดอก";
                                    <tr>
                                        <td>@row.Date.ToString("dd/MM/yyyy")</td>
                                        <td><span class="doc-no">@row.DocumentNo</span></td>
                                        <td><span class="type-badge @typeCss">@row.Type</span></td>
                                        <td>@row.MemberName</td>
                                        <td style="font-size:12px;color:#6b7280;">@row.Description</td>
                                        <td class="text-end @(row.Debit > 0 ? "debit-val" : "")">
                                            @(row.Debit > 0 ? row.Debit.ToString("N2") : "—")
                                        </td>
                                        <td class="text-end @(row.Credit > 0 ? "credit-val" : "")">
                                            @(row.Credit > 0 ? row.Credit.ToString("N2") : "—")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="bi bi-journal-x"></i>
                        ไม่พบรายการบัญชีในช่วงวันที่ที่เลือก
                    </div>
                }
            </div>
        </div>

        <!-- Document sidebar (ขวา) -->
        <div class="acc-card">
            <div class="acc-card-head">
                <h2><i class="bi bi-folder2-open" style="margin-right:6px;color:#059669"></i>ทะเบียนเอกสาร</h2>
                <span style="font-size:12px;color:#9ca3af;">@Model.Documents.Count ฉบับ</span>
            </div>
            <div class="acc-card-body">
                @if (Model.Documents.Any())
                {
                    <div class="doc-list">
                        @foreach (var doc in Model.Documents)
                        {
                            <div class="doc-item">
                                <div class="doc-item-head">
                                    <span class="doc-item-no">@doc.DocumentNo</span>
                                    <span class="doc-item-amt">฿@doc.Amount.ToString("N2")</span>
                                </div>
                                <div class="doc-item-meta">@doc.Category · @doc.MemberName</div>
                                <div class="doc-item-meta">@doc.Date.ToString("dd/MM/yyyy")</div>
                                @if (!string.IsNullOrEmpty(doc.Description))
                                {
                                    <div class="doc-item-meta" style="margin-top:2px;">@doc.Description</div>
                                }
                                <div class="doc-item-dl">
                                    <a class="btn-dl" href="@doc.DownloadUrl" target="_blank" rel="noopener">
                                        <i class="bi bi-download"></i> ดาวน์โหลด
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <i class="bi bi-folder-x"></i>
                        ยังไม่มีเอกสารในช่วงวันที่นี้
                    </div>
                }
            </div>
        </div>

    </div><!-- /main-grid -->

</div><!-- /container -->

<script>
async function calcInterest() {
    const yearBE = parseInt(document.getElementById('interestYear').value);
    const year   = yearBE - 543;
    const rate   = parseFloat(document.getElementById('interestRate').value);

    if (isNaN(year) || isNaN(rate) || rate <= 0) {
        return Swal.fire('ข้อมูลไม่ถูกต้อง', 'กรุณากรอกปีและอัตราดอกเบี้ยให้ครบ', 'warning');
    }

    const { isConfirmed } = await Swal.fire({
        title: `ยืนยันคิดดอกเบี้ยปี ${yearBE}?`,
        html: `อัตรา <b>${rate}%</b> ต่อปี<br>
               <small class="text-danger">ดำเนินการได้ครั้งเดียวต่อปี และจะบันทึกเข้ายอดเงินฝากสมาชิกทุกคน</small>`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#185FA5',
        confirmButtonText: 'ยืนยัน',
        cancelButtonText: 'ยกเลิก'
    });

    if (!isConfirmed) return;

    Swal.fire({ title: 'กำลังคำนวณ...', didOpen: () => Swal.showLoading() });

    try {
        const res  = await fetch('/Accounting/CalculateAnnualInterest', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ year, rate })
        });
        const data = await res.json();

        if (data.success) {
            const rows = data.results.map(r =>
                `<tr>
                    <td>${r.name}</td>
                    <td class="text-end">฿${Number(r.principal).toLocaleString('th-TH', { minimumFractionDigits: 2 })}</td>
                    <td class="text-end text-success fw-bold">+฿${Number(r.interest).toLocaleString('th-TH', { minimumFractionDigits: 2 })}</td>
                </tr>`
            ).join('');

            await Swal.fire({
                title: `คิดดอกเบี้ยปี ${yearBE} สำเร็จ`,
                html: `<div style="max-height:300px;overflow-y:auto;">
                           <table class="table table-sm">
                               <thead><tr><th>ชื่อ</th><th class="text-end">ยอดฝาก</th><th class="text-end">ดอกเบี้ย</th></tr></thead>
                               <tbody>${rows}</tbody>
                           </table>
                       </div>`,
                icon: 'success'
            });

            location.reload();
        } else {
            Swal.fire('ไม่สำเร็จ', data.message, 'error');
        }
    } catch {
        Swal.fire('ผิดพลาด', 'การเชื่อมต่อล้มเหลว กรุณาลองใหม่', 'error');
    }
}
</script>
