@{
    ViewData["Title"] = "เปลี่ยนรหัสผ่าน";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white fw-bold">เปลี่ยนรหัสผ่าน</div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger p-2 small">@ViewBag.Error</div>
                }
                @if (ViewBag.Success != null)
                {
                    <div class="alert alert-success p-2 small">@ViewBag.Success</div>
                }

                <form asp-controller="Auth" asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">รหัสผ่านปัจจุบัน</label>
                        <input type="password" name="currentPassword" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">รหัสผ่านใหม่</label>
                        <input type="password" name="newPassword" class="form-control" minlength="8" required />
                        <div class="form-text">อย่างน้อย 8 ตัวอักษร</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">ยืนยันรหัสผ่านใหม่</label>
                        <input type="password" name="confirmPassword" class="form-control" minlength="8" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">บันทึกรหัสผ่านใหม่</button>
                </form>
            </div>
        </div>
    </div>
</div>
