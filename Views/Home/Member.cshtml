window.deleteMember = async function(id, name) {
    const { value: pw } = await Swal.fire({
        title: 'ยืนยันการลบสมาชิก?',
        text: `คุณกำลังจะลบ "${name}" ข้อมูลทั้งหมดจะหายถาวร`,
        icon: 'warning', input: 'password',
        inputLabel: 'รหัสผ่านผู้ดูแลระบบ',
        showCancelButton: true, confirmButtonColor: '#dc2626',
        confirmButtonText: 'ยืนยันลบ', cancelButtonText: 'ยกเลิก'
    });
    if (pw === '1234') {
        Swal.fire({ title: 'กำลังลบ...', didOpen: () => Swal.showLoading() });
        const fd = new FormData(); fd.append('id', id);
        fetch('/Member/Delete', { method: 'POST', body: fd })
        .then(res => res.json())
        .then(res => {
            if (res.success) Swal.fire('สำเร็จ', 'ลบสมาชิกแล้ว', 'success').then(() => location.reload());
            else Swal.fire('ผิดพลาด', res.message, 'error');
        })
        .catch(() => Swal.fire('Error', 'การเชื่อมต่อล้มเหลว', 'error'));
    } else if (pw !== undefined) Swal.fire('รหัสผ่านไม่ถูกต้อง', '', 'error');
};

