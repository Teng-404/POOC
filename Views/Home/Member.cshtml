@model POOC.Models.MemberViewModel
@{
    ViewData["Title"] = "Member";
}

<style>
    .db-tabs { display: flex; gap: 2px; border-bottom: 1px solid #e5e7eb; margin-bottom: 1.5rem; }
    .db-tab { padding: 8px 16px; font-size: 14px; color: #6b7280; text-decoration: none; border-bottom: 2px solid transparent; margin-bottom: -1px; }
    .db-tab.active { color: #111827; border-bottom-color: #111827; font-weight: 500; }
    .db-tab:hover { color: #111827; text-decoration: none; }
    .db-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem; }
    .db-title { font-size: 22px; font-weight: 500; color: #111827; margin: 0 0 4px; }
    .db-subtitle { font-size: 13px; color: #6b7280; margin: 0; }

    .toolbar { display: flex; gap: 10px; margin-bottom: 1rem; }
    .btn-add { padding: 8px 18px; font-size: 13px; font-weight: 500; background: #185FA5; color: #fff; border: none; border-radius: 8px; cursor: pointer; white-space: nowrap; }
    .btn-add:hover { background: #0C447C; }

    .add-card { background: #fff; border: 0.5px solid #e5e7eb; border-radius: 12px; padding: 1rem 1.25rem; margin-bottom: 1rem; display: none; }
    .add-card.open { display: block; }
    .add-card-title { font-size: 13px; font-weight: 500; color: #111827; margin-bottom: 10px; }

    .member-table-wrap { background: #fff; border: 0.5px solid #e5e7eb; border-radius: 12px; overflow: hidden; margin-bottom: 2rem; }
    .member-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .member-table thead tr { background: #f9fafb; }
    .member-table th { padding: 10px 14px; text-align: left; font-weight: 500; color: #6b7280; font-size: 12px; border-bottom: 0.5px solid #e5e7eb; white-space: nowrap; }
    .member-table td { padding: 10px 14px; border-bottom: 0.5px solid #f3f4f6; color: #111827; vertical-align: middle; }
    .member-table tbody tr:last-child td { border-bottom: none; }
    .member-table tbody tr:hover { background: #fafafa; }
    .num-cell { color: #9ca3af; font-size: 12px; width: 36px; }
    .name-cell { display: flex; align-items: center; gap: 9px; }
    .avatar-sm { width: 28px; height: 28px; border-radius: 50%; background: #dbeafe; color: #185FA5; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 500; flex-shrink: 0; }
    .role-badge { display: inline-block; font-size: 11px; padding: 2px 8px; border-radius: 20px; background: #f3f4f6; color: #6b7280; }
    .action-group { display: flex; gap: 5px; flex-wrap: nowrap; }
    .btn-act { font-size: 12px; padding: 4px 10px; border-radius: 6px; border: 0.5px solid #e5e7eb; background: #fff; cursor: pointer; white-space: nowrap; }
    .btn-act.profile  { color: #b45309; border-color: #fde68a; background: #fffbeb; }
    .btn-act.profile:hover  { background: #fef3c7; }
    .btn-act.savings  { color: #185FA5; border-color: #bfdbfe; background: #eff6ff; }
    .btn-act.savings:hover  { background: #dbeafe; }
    .btn-act.loan     { color: #0F6E56; border-color: #99f6e4; background: #f0fdf4; }
    .btn-act.loan:hover     { background: #dcfce7; }
    .btn-act.del      { color: #dc2626; border-color: #fecaca; background: #fff5f5; }
    .btn-act.del:hover      { background: #fee2e2; }
    .empty-row { text-align: center; padding: 40px; color: #9ca3af; font-size: 13px; }

    .modal-content { border: 0.5px solid #e5e7eb; border-radius: 12px; box-shadow: 0 8px 32px rgba(0,0,0,0.08); }
    .modal-header { border-bottom: 0.5px solid #f3f4f6; padding: 1rem 1.25rem; }
    .modal-title { font-size: 15px; font-weight: 500; color: #111827; }
    .modal-footer { border-top: 0.5px solid #f3f4f6; padding: 0.75rem 1.25rem; }
    .modal-body { padding: 1.25rem; }
    .form-label-sm { font-size: 12px; color: #6b7280; margin-bottom: 4px; display: block; }
    .extra-info { background: #f9fafb; border: 0.5px solid #e5e7eb; border-radius: 8px; padding: 1rem; margin-top: 1rem; }
    .extra-info-title { font-size: 12px; color: #9ca3af; margin-bottom: 10px; }
    .btn-modal-save  { padding: 7px 20px; font-size: 13px; font-weight: 500; background: #185FA5; color: #fff; border: none; border-radius: 8px; cursor: pointer; }
    .btn-modal-save:hover  { background: #0C447C; }
    .btn-modal-close { padding: 7px 16px; font-size: 13px; background: #fff; color: #6b7280; border: 0.5px solid #e5e7eb; border-radius: 8px; cursor: pointer; }
    .btn-modal-close:hover { background: #f9fafb; }

    .loan-header-row { background: #f9fafb; border-radius: 8px; padding: 10px 14px; margin-bottom: 2px; font-size: 13px; }
    .badge-paid { display: inline-block; font-size: 11px; padding: 2px 8px; border-radius: 20px; background: #dcfce7; color: #166534; }
    .badge-partial { display: inline-block; font-size: 11px; padding: 2px 8px; border-radius: 20px; background: #fef3c7; color: #92400e; }
    .badge-pending { display: inline-block; font-size: 11px; padding: 2px 8px; border-radius: 20px; background: #eef2ff; color: #3730a3; }
    .badge-closed { display: inline-block; font-size: 11px; padding: 2px 8px; border-radius: 20px; background: #e5e7eb; color: #374151; }
    .btn-pay { font-size: 12px; padding: 3px 10px; border-radius: 6px; border: 0.5px solid #bfdbfe; background: #eff6ff; color: #185FA5; cursor: pointer; }
    .btn-pay:hover { background: #dbeafe; }
    .btn-pay:disabled { opacity: .5; cursor: not-allowed; }
    .btn-approve { font-size: 12px; padding: 4px 10px; border-radius: 6px; border: 0.5px solid #99f6e4; background: #f0fdf4; color: #0F6E56; cursor: pointer; }
    .btn-close-loan { font-size: 12px; padding: 4px 10px; border-radius: 6px; border: 0.5px solid #fde68a; background: #fffbeb; color: #b45309; cursor: pointer; }
    .btn-cancel-pay { font-size: 11px; padding: 2px 6px; border-radius: 6px; border: none; background: transparent; color: #dc2626; cursor: pointer; }

    .balance-display { background: #f9fafb; border: 0.5px solid #e5e7eb; border-radius: 8px; padding: 12px; text-align: center; margin-bottom: 1rem; }
    .balance-label  { font-size: 12px; color: #6b7280; margin-bottom: 4px; }
    .balance-amount { font-size: 22px; font-weight: 500; color: #185FA5; }

    @@media (max-width: 768px) {
        .action-group { flex-wrap: wrap; }
        .toolbar { flex-wrap: wrap; }
    }
</style>

<div class="container mt-4">

    <!-- TABS -->
    <div class="db-tabs">
        <a class="db-tab @(ViewContext.RouteData.Values["action"]?.ToString() == "Member" ? "active" : "")"
           asp-controller="Home" asp-action="Member">สมาชิก</a>
        <a class="db-tab @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")"
           asp-controller="Home" asp-action="Dashboard">ภาพรวม</a>
    </div>

    <!-- HEADER -->
    <div class="db-header">
        <div>
            <p class="db-title">
                รายชื่อสมาชิก
                <span id="overdueBadge" style="display:none; font-size:12px; background:#dc2626; color:#fff; border-radius:20px; padding:2px 10px; margin-left:8px; vertical-align:middle;">
                    <i class="bi bi-exclamation-triangle-fill"></i> <span id="overdueCount">0</span> งวดเกินกำหนด
                </span>
            </p>
            <p class="db-subtitle">ทั้งหมด @(Model.Members?.Count ?? 0) คน</p>
        </div>
        <div style="display:flex; gap:8px;">
            <button class="btn-add" style="background:#059669;" onclick="exportExcel()">
                <i class="bi bi-file-earmark-excel"></i> Export Excel
            </button>
            <button class="btn-add" onclick="toggleAddForm()">
                <i class="bi bi-plus-lg"></i> เพิ่มสมาชิก
            </button>
        </div>
    </div>

    <!-- ADD FORM -->
    <div class="add-card" id="addCard">
        <div class="add-card-title">ข้อมูลสมาชิกใหม่</div>
        <form asp-action="Add" asp-controller="Member" method="post">
            <div class="row g-2">
                <div class="col-md-4">
                    <input type="text" name="firstName" class="form-control form-control-sm" placeholder="ชื่อ" required />
                </div>
                <div class="col-md-4">
                    <input type="text" name="lastName" class="form-control form-control-sm" placeholder="นามสกุล" required />
                </div>
                <div class="col-md-3">
                    <input type="text" name="role" class="form-control form-control-sm" placeholder="อาชีพ" required />
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn-add w-100" style="padding:6px 0;">บันทึก</button>
                </div>
            </div>
        </form>
    </div>

    <!-- SEARCH -->
    <div class="toolbar">
        <input type="text" id="searchBox" class="form-control form-control-sm"
               placeholder="ค้นหาชื่อ นามสกุล หรืออาชีพ..."
               onkeyup="searchMember()" />
    </div>

    <!-- TABLE -->
    <div class="member-table-wrap">
        <table class="member-table">
            <thead>
                <tr>
                    <th class="num-cell">#</th>
                    <th>ชื่อ-นามสกุล</th>
                    <th>อาชีพ</th>
                    <th style="text-align:right;">จัดการ</th>
                </tr>
            </thead>
            <tbody id="memberTableBody">
                @if (Model.Members != null && Model.Members.Count > 0)
                {
                    for (int i = 0; i < Model.Members.Count; i++)
                    {
                        var m = Model.Members[i];
                        var initials = (m.FirstName.Length > 0 ? m.FirstName[0].ToString() : "")
                                     + (m.LastName.Length > 0  ? m.LastName[0].ToString()  : "");
                        <tr>
                            <td class="num-cell">@(i + 1)</td>
                            <td>
                                <div class="name-cell">
                                    <div class="avatar-sm">@initials</div>
                                    <span>@m.FirstName @m.LastName</span>
                                </div>
                            </td>
                            <td><span class="role-badge">@m.Role</span></td>
                            <td style="text-align:right;">
                                <div class="action-group" style="justify-content:flex-end;">
                                    <button class="btn-act profile"
                                            data-bs-toggle="modal" data-bs-target="#editModal"
                                            onclick="openEdit('@m.Id')">
                                        <i class="bi bi-person-lines-fill"></i> ประวัติ
                                    </button>
                                    <button class="btn-act savings"
                                            data-bs-toggle="modal" data-bs-target="#savingsModal"
                                            onclick="openSavings(@m.Id, '@m.FirstName')">
                                        <i class="bi bi-piggy-bank"></i> เงินฝาก
                                    </button>
                                    <button class="btn-act loan"
                                            data-bs-toggle="modal" data-bs-target="#loanModal"
                                            onclick="openLoan(@m.Id,'@m.FirstName','@m.LastName')">
                                        <i class="bi bi-file-earmark-text"></i> เงินกู้
                                    </button>
                                    <button class="btn-act del"
                                            onclick="deleteMember(@m.Id, '@m.FirstName @m.LastName')">
                                        <i class="bi bi-trash3"></i> ลบ
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="empty-row">
                            <i class="bi bi-people" style="font-size:24px; display:block; margin-bottom:8px;"></i>
                            ยังไม่มีสมาชิก กดปุ่ม "เพิ่มสมาชิก" เพื่อเริ่มต้น
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

<!-- ================= PROFILE MODAL ================= -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-person-lines-fill" style="margin-right:6px;"></i>ประวัติสมาชิก
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editId" />
                <div class="row g-2">
                    <div class="col-6">
                        <label class="form-label-sm">ชื่อ</label>
                        <input type="text" id="editFirstName" class="form-control form-control-sm" />
                    </div>
                    <div class="col-6">
                        <label class="form-label-sm">นามสกุล</label>
                        <input type="text" id="editLastName" class="form-control form-control-sm" />
                    </div>
                    <div class="col-12">
                        <label class="form-label-sm">อาชีพ</label>
                        <input type="text" id="editRole" class="form-control form-control-sm" />
                    </div>
                </div>
                <div class="extra-info">
                    <div class="extra-info-title">ข้อมูลเพิ่มเติม</div>
                    <div class="row g-2">
                        <div class="col-12">
                            <label class="form-label-sm">เลขบัตรประชาชน</label>
                            <input type="text" id="editCitizenId" class="form-control form-control-sm" placeholder="X-XXXX-XXXXX-XX-X" />
                        </div>
                        <div class="col-12">
                            <label class="form-label-sm">เบอร์โทรศัพท์</label>
                            <input type="text" id="editPhone" class="form-control form-control-sm" placeholder="0XX-XXX-XXXX" />
                        </div>
                        <div class="col-12">
                            <label class="form-label-sm">ที่อยู่</label>
                            <textarea id="editAddress" class="form-control form-control-sm" rows="2"></textarea>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-modal-close" data-bs-dismiss="modal">ปิด</button>
                <button type="button" class="btn-modal-save" onclick="saveEdit()">บันทึก</button>
            </div>
        </div>
    </div>
</div>

<!-- ================= LOAN MODAL ================= -->
<div class="modal fade" id="loanModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-file-earmark-text" style="margin-right:6px;"></i>
                    เงินกู้ของ <span id="loanName"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form onsubmit="loadSchedule(event)">
                    <input type="hidden" id="loanMemberId" />
                    <div class="row g-2 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label-sm">เงินกู้ (บาท)</label>
                            <input type="number" step="0.01" name="amount" class="form-control form-control-sm" placeholder="0.00" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label-sm">ดอกเบี้ย (%/ปี)</label>
                            <input type="number" step="0.01" name="rate" class="form-control form-control-sm" placeholder="0.00" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label-sm">จำนวนงวด</label>
                            <input type="number" name="months" class="form-control form-control-sm" placeholder="12" required />
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn-modal-save w-100">
                                <i class="bi bi-calculator"></i> คำนวณ
                            </button>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-sm">ชื่อผู้ค้ำประกัน</label>
                            <input type="text" name="guarantorName" class="form-control form-control-sm" placeholder="ชื่อ-นามสกุล" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-sm">เบอร์ผู้ค้ำประกัน</label>
                            <input type="text" name="guarantorPhone" class="form-control form-control-sm" placeholder="0XX-XXX-XXXX" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label-sm">ที่อยู่ผู้ค้ำประกัน</label>
                            <input type="text" name="guarantorAddress" class="form-control form-control-sm" placeholder="ที่อยู่โดยย่อ" />
                        </div>
                    </div>
                </form>

                <div style="margin: 1rem 0; border-top: 0.5px solid #f3f4f6;"></div>

                <div style="max-height: 380px; overflow-y: auto;">
                    <table class="member-table">
                        <thead>
                            <tr>
                                <th>งวด</th><th>ค่างวด</th><th>เงินต้น</th>
                                <th>ดอกเบี้ย</th><th>คงเหลือ</th>
                                <th>ครบกำหนด</th><th>สถานะ</th>
                            </tr>
                        </thead>
                        <tbody id="loanTableBody">
                            <tr><td colspan="7" class="empty-row" style="padding:20px;">กรอกข้อมูลแล้วกดคำนวณ</td></tr>
                        </tbody>
                    </table>
                </div>

                <div style="margin-top:10px; display:flex; justify-content:flex-end;">
                    <button class="btn-modal-save" onclick="saveLoan()">
                        <i class="bi bi-floppy"></i> บันทึกสัญญา
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ================= SAVINGS MODAL ================= -->
<div class="modal fade" id="savingsModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-piggy-bank" style="margin-right:6px;"></i>
                    เงินฝากของ <span id="savingsMemberName"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="savingsMemberId" />

                <div class="balance-display">
                    <div class="balance-label">ยอดเงินคงเหลือปัจจุบัน</div>
                    <div class="balance-amount" id="currentBalance">0.00</div>
                </div>

                <div class="row g-2 mb-3">
                    <div class="col-7">
                        <label class="form-label-sm">จำนวนเงิน (บาท)</label>
                        <input type="number" id="savingsAmount" class="form-control form-control-sm" placeholder="0.00" />
                    </div>
                    <div class="col-5">
                        <label class="form-label-sm">ประเภท</label>
                        <select id="transType" class="form-select form-select-sm">
                            <option value="deposit">ฝากเงิน (+)</option>
                            <option value="withdraw">ถอนเงิน (-)</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <button class="btn-modal-save w-100" onclick="saveSavings()">
                            <i class="bi bi-check-lg"></i> ยืนยันรายการ
                        </button>
                    </div>
                </div>

                <div style="border-top:0.5px solid #f3f4f6; margin-bottom:10px;"></div>

                <div style="max-height:320px; overflow-y:auto;">
                    <table class="member-table">
                        <thead>
                            <tr>
                                <th>#</th><th>วันที่</th><th>รายการ</th>
                                <th style="text-align:right;">จำนวน</th>
                                <th style="text-align:right;">คงเหลือ</th>
                            </tr>
                        </thead>
                        <tbody id="savingsHistoryBody">
                            <tr><td colspan="5" class="empty-row" style="padding:16px;">ยังไม่มีรายการ</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-modal-close" data-bs-dismiss="modal">ปิด</button>
            </div>
        </div>
    </div>
</div>

<!-- ================= JS ================= -->
<script>
function toggleAddForm() {
    document.getElementById('addCard').classList.toggle('open');
}

let searchTimer;
function searchMember() {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => {
        const keyword = document.getElementById('searchBox').value;
        fetch('/Member/Search?keyword=' + encodeURIComponent(keyword))
        .then(res => res.json())
        .then(data => {
            let html = '';
            if (!data || data.length === 0) {
                html = `<tr><td colspan="4" class="empty-row">ไม่พบสมาชิกที่ค้นหา</td></tr>`;
            } else {
                data.forEach((m, i) => {
                    const initials = (m.firstName?.[0] ?? '') + (m.lastName?.[0] ?? '');
                    html += `<tr>
                        <td class="num-cell">${i + 1}</td>
                        <td><div class="name-cell">
                            <div class="avatar-sm">${initials}</div>
                            <span>${m.firstName} ${m.lastName}</span>
                        </div></td>
                        <td><span class="role-badge">${m.role}</span></td>
                        <td style="text-align:right;">
                            <div class="action-group" style="justify-content:flex-end;">
                                <button class="btn-act profile" data-bs-toggle="modal" data-bs-target="#editModal"
                                    onclick="openEdit(${m.id})">
                                    <i class="bi bi-person-lines-fill"></i> ประวัติ</button>
                                <button class="btn-act savings" data-bs-toggle="modal" data-bs-target="#savingsModal"
                                    onclick="openSavings(${m.id},'${m.firstName}')">
                                    <i class="bi bi-piggy-bank"></i> เงินฝาก</button>
                                <button class="btn-act loan" data-bs-toggle="modal" data-bs-target="#loanModal"
                                    onclick="openLoan(${m.id},'${m.firstName}','${m.lastName}')">
                                    <i class="bi bi-file-earmark-text"></i> เงินกู้</button>
                                <button class="btn-act del"
                                    onclick="deleteMember(${m.id},'${m.firstName} ${m.lastName}')">
                                    <i class="bi bi-trash3"></i> ลบ</button>
                            </div>
                        </td>
                    </tr>`;
                });
            }
            document.getElementById('memberTableBody').innerHTML = html;
        });
    }, 300);
}

function openEdit(id) {
    fetch('/Member/GetMemberDetail?id=' + id)
    .then(res => res.json())
    .then(res => {
        if (res.success) {
            document.getElementById('editId').value        = res.data.id;
            document.getElementById('editFirstName').value = res.data.firstName;
            document.getElementById('editLastName').value  = res.data.lastName;
