@model POOC.Models.MemberViewModel

<ul class="nav nav-tabs">
    <li class="nav-item">
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Member" ? "active" : "")" 
           asp-controller="Home" asp-action="Member">สมาชิก</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")" 
           asp-controller="Home" asp-action="Dashboard">ข้อมูลกู้ยืม</a>
    </li>
</ul>

<div class="tab-content mt-3">

<!-- ================= MEMBER ================= -->
    <div class="tab-pane fade show active" id="memberTab">

        <div class="container mt-4">

            <!-- SEARCH -->
            <input type="text" id="searchBox"
                class="form-control mb-2"
                placeholder="ค้นหาสมาชิก..."
                onkeyup="searchMember()" />

            <!-- ADD MEMBER -->
            <form asp-action="Add" asp-controller="Member" method="post" class="row g-2 mt-3">
                <div class="col-md-4">
                    <input type="text" name="firstName" class="form-control" placeholder="ชื่อ" required />
                </div>

                <div class="col-md-4">
                    <input type="text" name="lastName" class="form-control" placeholder="นามสกุล" required />
                </div>

                <div class="col-md-3">
                    <input type="text" name="role" class="form-control" placeholder="อาชีพ" required />
                </div>

                <div class="col-md-1">
                    <button class="btn btn-primary w-100">+</button>
                </div>
            </form>

            <!-- TABLE -->
            <table class="table table-bordered mt-4">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>ชื่อ</th>
                        <th>นามสกุล</th>
                        <th>อาชีพ</th>
                        <th>จัดการ</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Members != null && Model.Members.Count > 0)
                    {
                        for (int i = 0; i < Model.Members.Count; i++)
                        {
                            var m = Model.Members[i];

                            <tr>
                                <td>@(i + 1)</td>

                                <td>@m.FirstName</td>
                                <td>@m.LastName</td>
                                <td>@m.Role</td>

                                <td>

                                    <!-- PROFILE -->
                                    <button class="btn btn-warning btn-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editModal"
                                            onclick="openEdit('@m.Id','@m.FirstName','@m.LastName','@m.Role','@m.CitizenId','@m.Phone','@m.Address')">
                                        ประวัติ
                                    </button>

                                    <!-- LOAN -->
                                    <button class="btn btn-info btn-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#loanModal"
                                            onclick="openLoan(@m.Id,'@m.FirstName','@m.LastName')">
                                        เงินกู้
                                    </button>

                                    <!-- DELETE -->
                                    @* <form asp-action="Delete" asp-controller="Member" method="post" ...>
                                        <input type="hidden" name="id" value="@m.Id" />
                                        <button class="btn btn-danger btn-sm">ลบ</button>
                                    </form> 
                                    *@
                                    <button class="btn btn-danger btn-sm" onclick="deleteMember(@m.Id, '@m.FirstName @m.LastName')">ลบ</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">ไม่มีข้อมูล</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>

<!-- ================= PROFILE MODAL ================= -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">ประวัติสมาชิก</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <input type="hidden" id="editId" />

                <div class="mb-2">
                    <label>ชื่อ</label>
                    <input type="text" id="editFirstName" class="form-control" />
                </div>

                <div class="mb-2">
                    <label>นามสกุล</label>
                    <input type="text" id="editLastName" class="form-control" />
                </div>

                <div class="mb-2">
                    <label>อาชีพ</label>
                    <input type="text" id="editRole" class="form-control" />
                </div>

                <div class="mt-4 p-3 border rounded bg-light">
                    <h6 class="text-muted border-bottom pb-2">
                        <i class="bi bi-info-circle"></i> ข้อมูลเพิ่มเติมอื่น ๆ
                    </h6>
                    <div class="mb-2">
                        <label class="form-label small fw-bold">เลขบัตรประชาชน</label>
                        <input type="text" id="editCitizenId" class="form-control form-control-sm" placeholder="X-XXXX-XXXXX-XX-X" />
                    </div>

                    <div class="mb-2">
                        <label class="form-label small fw-bold">เบอร์โทรศัพท์</label>
                        <input type="text" id="editPhone" class="form-control form-control-sm" placeholder="0XX-XXX-XXXX" />
                    </div>

                    <div class="mb-2">
                        <label class="form-label small fw-bold">ที่อยู่</label>
                        <textarea id="editAddress" class="form-control form-control-sm" rows="2"></textarea>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">ปิด</button>
                <button type="button" class="btn btn-success" onclick="saveEdit()">บันทึก</button>
            </div>

        </div>
    </div>
</div>

<!-- ================= LOAN MODAL ================= -->
<div class="modal fade" id="loanModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">
                    ตารางเงินกู้ของ <span id="loanName"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <!-- FORM LOAN -->
                <form onsubmit="loadSchedule(event)">

                    <input type="hidden" id="loanMemberId" />

                    <div class="row g-2">

                        <div class="col-md-4">
                            <input type="number" step="0.01" name="amount" class="form-control" placeholder="เงินกู้" required />
                        </div>

                        <div class="col-md-4">
                            <input type="number" step="0.01" name="rate" class="form-control" placeholder="ดอกเบี้ย (%)" required />
                        </div>

                        <div class="col-md-4">
                            <input type="number" name="months" class="form-control" placeholder="งวด" required />
                        </div>

                    </div>

                    <button class="btn btn-success mt-2">คำนวณ</button>

                </form>

                <hr />

                <!-- TABLE AJAX -->
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>งวด</th>
                            <th>ค่างวด</th>
                            <th>เงินต้น</th>
                            <th>ดอกเบี้ย</th>
                            <th>คงเหลือ</th>
                            <th>สถานะ</th>
                        </tr>
                    </thead>

                    <tbody id="loanTableBody">
                        <tr>
                            <td colspan="6" class="text-center">ยังไม่มีข้อมูล</td>
                        </tr>
                    </tbody>

                </table>
                <button class="btn btn-primary mt-2" onclick="saveLoan()">บันทึก</button>
            </div>

        </div>
    </div>
</div>

<!-- ================= JS ================= -->
<script>
// --- ส่วนของสมาชิก (Member) ---

function addMember(e) {
    e.preventDefault(); // ป้องกันการรีโหลดหน้าจาก Form
    let firstName = document.querySelector("input[name='firstName']").value;
    let lastName = document.querySelector("input[name='lastName']").value;
    let role = document.querySelector("input[name='role']").value;

    Swal.fire({ title: 'กำลังบันทึก...', didOpen: () => { Swal.showLoading() } });

    fetch('/Member/Add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ firstName, lastName, role })
    })
    .then(res => res.json())
    .then(res => {
        if (res.success) {
            Swal.fire('สำเร็จ!', 'เพิ่มสมาชิกเรียบร้อยแล้ว', 'success')
            .then(() => location.reload());
        } else {
            Swal.fire('ผิดพลาด', res.message, 'error');
        }
    });
}

let timer;
function searchMember() {
    clearTimeout(timer);
    timer = setTimeout(() => {
        let keyword = document.getElementById("searchBox").value;
        fetch('/Member/Search?keyword=' + keyword)
        .then(res => res.json())
        .then(data => {
            let html = "";
            if (!data || data.length === 0) {
                html = `<tr><td colspan="5" class="text-center">ไม่พบข้อมูล</td></tr>`;
            }
            data.forEach((m, i) => {
                html += `
                <tr>
                    <td>${i + 1}</td>
                    <td>${m.firstName}</td>
                    <td>${m.lastName}</td>
                    <td>${m.role}</td>
                    <td>
                        <button class="btn btn-warning btn-sm" 
                                data-bs-toggle="modal" 
                                data-bs-target="#editModal" 
                                onclick="openEdit('${m.id}','${m.firstName}','${m.lastName}','${m.role}','${m.citizenId}','${m.phone}','${m.address}')">
                            ประวัติ
                        </button>
                        <button class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#loanModal"
                            onclick="openLoan(${m.id},'${m.firstName}','${m.lastName}')">เงินกู้</button>
                        <button class="btn btn-danger btn-sm" onclick="deleteMember(${m.id}, '${m.firstName} ${m.lastName}')">ลบ</button>
                    </td>
                </tr>`;
            });
            document.querySelector("table tbody").innerHTML = html;
        });
    }, 300);
}

function openEdit(id) {
    fetch('/Member/GetMemberDetail?id=' + id)
    .then(res => res.json())
    .then(res => {
        if (res.success) {
            document.getElementById("editId").value = res.data.id;
            document.getElementById("editFirstName").value = res.data.firstName;
            document.getElementById("editLastName").value = res.data.lastName;
            document.getElementById("editRole").value = res.data.role;
            document.getElementById("editCitizenId").value = res.data.citizenId || "";
            document.getElementById("editPhone").value = res.data.phone || "";
            document.getElementById("editAddress").value = res.data.address || "";
        }
    });
}

function saveEdit() {
    const data = {
        Id: parseInt(document.getElementById("editId").value),
        FirstName: document.getElementById("editFirstName").value,
        LastName: document.getElementById("editLastName").value,
        Role: document.getElementById("editRole").value,
        CitizenId: document.getElementById("editCitizenId").value,
        Phone: document.getElementById("editPhone").value,
        Address: document.getElementById("editAddress").value
    };

    if (isNaN(data.Id)) return Swal.fire('ผิดพลาด', 'ไม่พบรหัสสมาชิก', 'error');

    Swal.fire({ title: 'กำลังบันทึก...', didOpen: () => { Swal.showLoading() } });

    fetch('/Member/UpdateMember', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    })
    .then(res => res.json())
    .then(res => {
        if (res.success) {
            Swal.fire('สำเร็จ', 'อัปเดตข้อมูลแล้ว', 'success').then(() => location.reload());
        } else {
            Swal.fire('ผิดพลาด', res.message, 'error');
        }
    })
    .catch(err => Swal.fire('ผิดพลาด', 'การเชื่อมต่อเซิร์ฟเวอร์ล้มเหลว', 'error'));
}

// --- ส่วนของเงินกู้ (Loan) ---

function openLoan(id, firstName, lastName) {
    document.getElementById("loanMemberId").value = id;
    document.getElementById("loanName").innerText = firstName + " " + lastName;
    document.getElementById("loanTableBody").innerHTML = "<tr><td colspan='6' class='text-center'>กรอกข้อมูลแล้วกดคำนวณ</td></tr>";
    loadLoanHistory(id);
}

function loadSchedule(e) {
    e.preventDefault();
    let memberId = parseInt(document.getElementById("loanMemberId").value);
    let amount = e.target.amount.value;
    let rate = e.target.rate.value;
    let months = e.target.months.value;

    document.getElementById("loanTableBody").innerHTML = "<tr><td colspan='6' class='text-center'>กำลังคำนวณ...</td></tr>";

    fetch(`/Loan/GetLoanSchedule?memberId=${memberId}&amount=${amount}&rate=${rate}&months=${months}`)
    .then(res => res.json())
    .then(data => {
        let html = "";
        data.forEach(x => {
            html += `
            <tr>
                <td>${x.installment}</td>
                <td>${x.payment.toFixed(2)}</td>
                <td>${x.principal.toFixed(2)}</td>
                <td>${x.interest.toFixed(2)}</td>
                <td>${x.balance.toFixed(2)}</td>
                <td>-</td>
            </tr>`;
        });
        document.getElementById("loanTableBody").innerHTML = html;
    });
}

function saveLoan() {
    let memberId = parseInt(document.getElementById("loanMemberId").value);
    let amount = document.querySelector("input[name='amount']").value;
    let rate = document.querySelector("input[name='rate']").value;
    let months = document.querySelector("input[name='months']").value;

    fetch('/Loan/Create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ memberId, amount, rate, months })
    })
    .then(res => res.json())
    .then(res => {
        if (res.success) {
            alert("บันทึกสำเร็จ");
            loadLoanHistory(memberId);
        } else {
            alert(res.message);
        }
    });
}

function loadLoanHistory(memberId) {
    fetch('/Loan/GetLoanHistory?memberId=' + memberId)
    .then(res => res.json())
    .then(data => {
        let html = "";
        if (!data || data.length === 0) {
            document.getElementById("loanTableBody").innerHTML = "<tr><td colspan='6' class='text-center'>ไม่มีข้อมูล</td></tr>";
            return;
        }

        data.forEach(loan => {
            html += `
            <tr style="background:#eee">
                <td colspan="6">
                    <div class="d-flex justify-content-between align-items-center">
                        <span>
                            <strong>เงินกู้:</strong> ${loan.amount.toLocaleString()} | 
                            <strong>ดอกเบี้ย:</strong> ${loan.rate}% | 
                            <strong>งวด:</strong> ${loan.months}
                        </span>
                        <div>
                            <a href="/Loan/DownloadContract?loanId=${loan.id}" target="_blank" class="btn btn-primary btn-sm me-1">
                                <i class="fas fa-file-pdf"></i>พิมพ์สัญญา
                            </a>
                            <button class="btn btn-danger btn-sm" onclick="deleteLoan(${loan.id})">ลบสัญญา</button>
                        </div>
                    </div>
                </td>
            </tr>`;

            loan.loanDetails.forEach(d => {
                let statusContent = d.isPaid 
                    ? `<span class="badge bg-success">จ่ายแล้ว</span>
                       <button class="btn btn-link btn-sm text-danger p-0 ms-2" onclick="confirmCancelPay(${d.id})"><i class="bi bi-x-circle"></i>ยกเลิก</button>`
                    : `<button class="btn btn-sm btn-primary" onclick="payMoney(${d.id})">จ่ายเงิน</button>`;
                
                html += `
                <tr>
                    <td>${d.installment}</td>
                    <td>${d.payment.toFixed(2)}</td>
                    <td>${d.principal.toFixed(2)}</td>
                    <td>${d.interest > 0 ? d.interest.toFixed(2) : "-"}</td>
                    <td>${d.balance.toFixed(2)}</td>
                    <td>${statusContent}</td>
                </tr>`;
            });
        });
        document.getElementById("loanTableBody").innerHTML = html;
    });
}

// --- ส่วนของระบบความปลอดภัย (Delete & Cancel) ---

window.deleteMember = async function(id, name) {
    const { value: password } = await Swal.fire({
        title: 'ยืนยันการลบสมาชิก?',
        text: `คุณกำลังจะลบคุณ "${name}" ข้อมูลสัญญาและประวัติทั้งหมดจะหายไปถาวร!`,
        icon: 'warning',
        input: 'password',
        inputLabel: 'กรุณาใส่รหัสผ่านเพื่อยืนยัน',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        confirmButtonText: 'ยืนยันการลบ',
        cancelButtonText: 'ยกเลิก'
    });

    if (password === "1234") {
        Swal.fire({ title: 'กำลังลบ...', didOpen: () => { Swal.showLoading() } });

        // ส่ง ID ไปที่ MemberController
        let formData = new FormData();
        formData.append("id", id);

        fetch('/Member/Delete', {
            method: 'POST',
            body: formData
        })
        .then(res => res.json())
        .then(res => {
            if (res.success) {
                Swal.fire('สำเร็จ!', 'ลบสมาชิกเรียบร้อยแล้ว', 'success')
                .then(() => location.reload()); // รีโหลดเพื่อให้รายชื่อในตารางอัปเดต
            } else {
                Swal.fire('ผิดพลาด', res.message, 'error');
            }
        })
        .catch(err => Swal.fire('Error', 'การเชื่อมต่อล้มเหลว', 'error'));
    } else if (password !== undefined) {
        Swal.fire('รหัสผ่านไม่ถูกต้อง!', '', 'error');
    }
};

window.deleteLoan = async function(id) {
    const { value: password } = await Swal.fire({
        title: 'ยืนยันการลบสัญญา',
        text: "เมื่อลบแล้ว ประวัติทั้งหมดจะหายไปถาวร!",
        input: 'password',
        inputLabel: 'กรุณาใส่รหัสผ่านเพื่อยืนยัน',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        confirmButtonText: 'ยืนยันการลบ',
        cancelButtonText: 'ยกเลิก'
    });

    if (password === "1234") {
        Swal.fire({ title: 'กำลังประมวลผล...', didOpen: () => { Swal.showLoading() } });
        fetch('/Loan/Delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: parseInt(id) })
        })
        .then(res => res.json())
        .then(res => {
            if (res.success) {
                Swal.fire('สำเร็จ!', 'ลบสัญญาเรียบร้อยแล้ว', 'success');
                loadLoanHistory(document.getElementById("loanMemberId").value);
            } else {
                Swal.fire('ผิดพลาด', res.message || 'ไม่สามารถลบได้', 'error');
            }
        }).catch(() => Swal.fire('Error', 'การเชื่อมต่อล้มเหลว', 'error'));
    } else if (password !== undefined) {
        Swal.fire('รหัสผ่านไม่ถูกต้อง!', '', 'error');
    }
};

async function confirmCancelPay(id) {
    const { value: password } = await Swal.fire({
        title: 'ยืนยันการยกเลิกชำระเงิน',
        input: 'password',
        inputLabel: 'กรุณาใส่รหัสผ่านผู้ดูแลระบบ',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        confirmButtonText: 'ยืนยันยกเลิก'
    });

    if (password === "1234") {
        fetch('/Loan/CancelPayment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ detailId: id })
        })
        .then(res => res.json())
        .then(res => {
            if (res.success) {
                Swal.fire('สำเร็จ!', 'ยกเลิกรายการเรียบร้อยแล้ว', 'success');
                loadLoanHistory(document.getElementById("loanMemberId").value);
            } else {
                Swal.fire('เกิดข้อผิดพลาด', res.message, 'error');
            }
        });
    } else if (password !== undefined) {
        Swal.fire('รหัสผ่านไม่ถูกต้อง', '', 'error');
    }
}

function payMoney(id) {
    Swal.fire({
        title: 'ยืนยันการชำระเงิน?',
        text: "คุณต้องการบันทึกการชำระเงินงวดนี้ใช่หรือไม่?",
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#3085d6',
        cancelButtonColor: '#d33',
        confirmButtonText: 'ใช่, จ่ายเงินแล้ว',
        cancelButtonText: 'ยกเลิก'
    }).then((result) => {
        if (result.isConfirmed) {
            fetch('/Loan/PayInstallment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ detailId: id })
            })
            .then(res => res.json())
            .then(res => {
                if (res.success) {
                    Swal.fire('สำเร็จ!', 'บันทึกการจ่ายเงินแล้ว', 'success');
                    loadLoanHistory(document.getElementById("loanMemberId").value); 
                } else {
                    Swal.fire('ผิดพลาด', res.message || "เกิดข้อผิดพลาด", 'error');
                }
            });
        }
    });
}
</script>