function approveLoan(id) {
    Swal.fire({
        title: 'อนุมัติเงินกู้?', text: 'หลังอนุมัติแล้วจะสามารถรับชำระเงินได้',
        icon: 'question', showCancelButton: true,
        confirmButtonColor: '#0F6E56', confirmButtonText: 'อนุมัติ', cancelButtonText: 'ยกเลิก'
    }).then(result => {
        if (!result.isConfirmed) return;
        fetch('/Loan/Approve', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ loanId: id })
        })
        .then(res => res.json())
        .then(res => {
            if (res.success) { Swal.fire('สำเร็จ', 'อนุมัติเงินกู้แล้ว', 'success'); loadLoanHistory(document.getElementById('loanMemberId').value); }
            else Swal.fire('ผิดพลาด', res.message || 'ไม่สามารถอนุมัติได้', 'error');
        });
    });
}

function closeLoanEarly(id) {
    Swal.fire({
        title: 'ปิดบัญชีก่อนกำหนด?',
        text: 'ระบบจะบันทึกงวดที่เหลือทั้งหมดเป็นชำระแล้วและปิดสัญญา',
        icon: 'warning', showCancelButton: true,
        confirmButtonColor: '#b45309', confirmButtonText: 'ปิดบัญชี', cancelButtonText: 'ยกเลิก'
    }).then(result => {
        if (!result.isConfirmed) return;
        fetch('/Loan/CloseEarly', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ loanId: id })
        })
        .then(res => res.json())
        .then(res => {
            if (res.success) { Swal.fire('สำเร็จ', 'ปิดบัญชีเงินกู้แล้ว', 'success'); loadLoanHistory(document.getElementById('loanMemberId').value); }
            else Swal.fire('ผิดพลาด', res.message || 'ไม่สามารถปิดบัญชีได้', 'error');
        });
    });
}

function payMoney(id, remainingPayment) {
    Swal.fire({
        title: 'บันทึกการชำระเงิน',
        text: `ยอดคงเหลืองวดนี้ ฿${Number(remainingPayment).toLocaleString('th-TH', { minimumFractionDigits: 2 })}`,
        icon: 'question', input: 'number',
        inputValue: Number(remainingPayment).toFixed(2),
        inputAttributes: { min: 0.01, max: remainingPayment, step: 0.01 },
        showCancelButton: true, confirmButtonColor: '#185FA5',
        confirmButtonText: 'บันทึกชำระ', cancelButtonText: 'ยกเลิก',
        inputValidator: value => {
            const amount = parseFloat(value);
            if (isNaN(amount) || amount <= 0) return 'กรุณาระบุยอดชำระให้ถูกต้อง';
            if (amount > Number(remainingPayment) + 0.01) return 'ยอดชำระเกินยอดคงเหลืองวดนี้';
        }
    }).then(result => {
        if (result.isConfirmed) {
            fetch('/Loan/PayInstallment', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ detailId: id, amount: parseFloat(result.value) })
            })
            .then(res => res.json())
            .then(res => {
                if (res.success) { Swal.fire('สำเร็จ', 'บันทึกการจ่ายเงินแล้ว', 'success'); loadLoanHistory(document.getElementById('loanMemberId').value); }
                else Swal.fire('ผิดพลาด', res.message || 'เกิดข้อผิดพลาด', 'error');
            });
        }
    });
}

