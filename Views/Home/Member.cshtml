        body: JSON.stringify(data)
    })
    .then(res => res.json())
    .then(res => {
        if (res.success) Swal.fire('สำเร็จ', 'บันทึกรายการแล้ว', 'success').then(() => location.reload());
        else Swal.fire('ผิดพลาด', res.message, 'error');
