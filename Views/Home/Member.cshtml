function loadSchedule(e) {
    e.preventDefault();
    const memberId = parseInt(document.getElementById('loanMemberId').value);
    const { amount, rate, months } = e.target;
    document.getElementById('loanTableBody').innerHTML =
        '<tr><td colspan="7" class="empty-row" style="padding:16px;">กำลังคำนวณ...</td></tr>';
    fetch(`/Loan/GetLoanSchedule?memberId=${memberId}&amount=${amount.value}&rate=${rate.value}&months=${months.value}`)
    .then(res => res.json())
    .then(data => {
        document.getElementById('loanTableBody').innerHTML = data.map(x => `<tr>
            <td>${x.installment}</td>
            <td>${x.payment.toFixed(2)}</td>
            <td>${x.principal.toFixed(2)}</td>
            <td>${x.interest.toFixed(2)}</td>
            <td>${x.balance.toFixed(2)}</td>
            <td style="color:#9ca3af;">-</td>
            <td><span class="badge-pending">ตัวอย่าง</span></td>
