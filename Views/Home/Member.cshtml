        title: 'ยืนยันยกเลิกชำระเงิน',
        input: 'password', inputLabel: 'รหัสผ่านผู้ดูแลระบบ',
        showCancelButton: true, confirmButtonColor: '#dc2626', confirmButtonText: 'ยืนยัน'
    });
    if (pw === '1234') {
        fetch('/Loan/CancelPayment', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ detailId: id })
        })
        .then(res => res.json())
        .then(res => {
            if (res.success) { Swal.fire('สำเร็จ', 'ยกเลิกรายการแล้ว', 'success'); loadLoanHistory(document.getElementById('loanMemberId').value); }
