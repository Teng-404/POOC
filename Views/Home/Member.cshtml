function saveLoan() {
    const memberId = parseInt(document.getElementById('loanMemberId').value);
    const amount   = document.querySelector("input[name='amount']").value;
    const rate     = document.querySelector("input[name='rate']").value;
    const months   = document.querySelector("input[name='months']").value;
    const guarantorName    = document.querySelector("input[name='guarantorName']").value;
    const guarantorPhone   = document.querySelector("input[name='guarantorPhone']").value;
    const guarantorAddress = document.querySelector("input[name='guarantorAddress']").value;
    Swal.fire({ title: 'กำลังบันทึก...', didOpen: () => Swal.showLoading() });
    fetch('/Loan/Create', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ memberId, amount, rate, months, guarantorName, guarantorPhone, guarantorAddress })
    })
    .then(res => res.json())
    .then(res => {
        if (res.success) { Swal.fire('สำเร็จ', 'บันทึกคำขอแล้ว กรุณาอนุมัติเงินกู้ก่อนรับชำระ', 'success'); loadLoanHistory(memberId); }
        else Swal.fire('ผิดพลาด', res.message, 'error');
    });
}

function loadLoanHistory(memberId) {
    fetch('/Loan/GetLoanHistoryWithOverdue?memberId=' + memberId)
    .then(res => res.json())
    .then(data => {
        if (!data || data.length === 0) {
            document.getElementById('loanTableBody').innerHTML =
                '<tr><td colspan="7" class="empty-row" style="padding:20px;">ยังไม่มีสัญญากู้</td></tr>';
            return;
        }
        let html = '';
        data.forEach(loan => {
            const statusClass = loan.status === 'Pending' ? 'badge-pending'
                : loan.status === 'PartialPaid' ? 'badge-partial'
                : loan.status === 'Closed' ? 'badge-closed'
                : 'badge-paid';
            const guarantor = loan.guarantorName
                ? `&nbsp;|&nbsp; ผู้ค้ำ: <strong>${loan.guarantorName}</strong>`
                : '';
            const loanActions = loan.status === 'Pending'
                ? `<button class="btn-approve" onclick="approveLoan(${loan.id})"><i class="bi bi-check2-circle"></i> อนุมัติ</button>`
                : loan.status !== 'Closed'
                    ? `<button class="btn-close-loan" onclick="closeLoanEarly(${loan.id})"><i class="bi bi-door-closed"></i> ปิดบัญชีก่อนกำหนด</button>`
                    : '';
            html += `<tr><td colspan="7" style="padding:0;">
                <div class="loan-header-row">
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <span style="font-size:13px; color:#374151;">
                            <strong>฿${loan.amount.toLocaleString('th-TH')}</strong>
                            &nbsp;|&nbsp; ดอกเบี้ย <strong>${loan.rate}%</strong>
                            &nbsp;|&nbsp; <strong>${loan.months}</strong> งวด
                            &nbsp;|&nbsp; <span class="${statusClass}">${loan.statusText}</span>
                            &nbsp;|&nbsp; ชำระแล้ว <strong>฿${loan.paidAmount.toLocaleString('th-TH', { minimumFractionDigits: 2 })}</strong>
                            ${guarantor}
                        </span>
                        <div style="display:flex; gap:6px;">
                            ${loanActions}
                            <a href="/Loan/DownloadContract?loanId=${loan.id}" target="_blank"
                               style="font-size:12px; padding:4px 10px; border-radius:6px; border:0.5px solid #bfdbfe; background:#eff6ff; color:#185FA5; text-decoration:none;">
                                <i class="bi bi-file-pdf"></i> พิมพ์สัญญา
                            </a>
                            <button class="btn-act del" style="font-size:12px;" onclick="deleteLoan(${loan.id})">
                                <i class="bi bi-trash3"></i> ลบ
                            </button>
                        </div>
                    </div>
                </div>
            </td></tr>`;
            
            loan.loanDetails.forEach(d => {
                const dueDateStr = new Date(d.dueDate).toLocaleDateString('th-TH', {year:'numeric',month:'short',day:'numeric'});
                
                let rowStyle = '';
                let overdueTag = '';
                if (d.isOverdue) {
                    rowStyle = 'background:#fff5f5;';
                    overdueTag = `<div style="font-size:10px; color:#dc2626; margin-top:2px;">
                        <i class="bi bi-exclamation-triangle-fill"></i> เกิน ${d.monthsLate} เดือน
                        | ค่าปรับ ฿${d.penalty.toFixed(2)}
                    </div>`;
                }
                
                const paidInfo = d.paidAmount > 0 && !d.isPaid
                    ? `<div style="font-size:10px; color:#92400e; margin-top:2px;">จ่ายแล้ว ฿${d.paidAmount.toFixed(2)} / เหลือ ฿${d.remainingPayment.toFixed(2)}</div>`
                    : '';
                const paymentDisabled = (loan.status !== 'Active' && loan.status !== 'PartialPaid') ? 'disabled title="ต้องอนุมัติเงินกู้ก่อน"' : '';
                const statusContent = d.isPaid
                    ? `<span class="badge-paid">จ่ายแล้ว</span>
                       <button class="btn-cancel-pay" onclick="confirmCancelPay(${d.id})">
                           <i class="bi bi-x-circle"></i> ยกเลิก</button>`
                    : d.paidAmount > 0
                        ? `<span class="badge-partial">ชำระบางส่วน</span>
                           ${paidInfo}
                           <button class="btn-pay" ${paymentDisabled} onclick="payMoney(${d.id}, ${d.remainingPayment.toFixed(2)})">ชำระเพิ่ม</button>`
                    : d.isOverdue
                        ? `<button class="btn-pay" ${paymentDisabled} style="background:#fff0f0; border-color:#fca5a5; color:#dc2626;" onclick="payMoney(${d.id}, ${d.remainingPayment.toFixed(2)})">
                               <i class="bi bi-exclamation-circle"></i> จ่ายเงิน
                           </button>`
                        : `<button class="btn-pay" ${paymentDisabled} onclick="payMoney(${d.id}, ${d.remainingPayment.toFixed(2)})">จ่ายเงิน</button>`;

                html += `<tr style="${rowStyle}">
                    <td>${d.installment}</td>
                    <td>
                        <div>${d.payment.toFixed(2)}</div>
                        ${d.isOverdue ? `<div style="font-size:10px;color:#dc2626;">+฿${d.penalty.toFixed(2)}</div>` : ''}
                    </td>
                    <td>${d.principal.toFixed(2)}</td>
                    <td>${d.interest > 0 ? d.interest.toFixed(2) : '-'}</td>
                    <td>${d.balance.toFixed(2)}</td>
                    <td>
                        <div style="font-size:11px; color:#9ca3af;">${dueDateStr}</div>
                        ${overdueTag}
                    </td>
                    <td>${statusContent}</td>
                </tr>`;
            });
        });
        document.getElementById('loanTableBody').innerHTML = html;
    });
}

function openSavings(id, name) {
    document.getElementById('savingsMemberId').value    = id;
    document.getElementById('savingsMemberName').innerText = name;
    document.getElementById('savingsAmount').value      = '';
    fetch('/Member/GetSavingsBalance?memberId=' + id)
    .then(res => res.json())
    .then(data => {
        document.getElementById('currentBalance').innerText =
            data.balance.toLocaleString('th-TH', { minimumFractionDigits: 2 });
        let html = '';
        if (data.history && data.history.length > 0) {
            data.history.forEach((item, index) => {
                const date      = new Date(item.transactionDate).toLocaleDateString('th-TH');
                const isDeposit = item.amount >= 0;
                html += `<tr>
                    <td style="color:#9ca3af;">${index + 1}</td>
                    <td>${date}</td>
                    <td>${item.description}</td>
                    <td style="text-align:right; color:${isDeposit ? '#059669' : '#dc2626'}; font-weight:500;">
                        ${isDeposit ? '+' : ''}${item.amount.toLocaleString('th-TH', { minimumFractionDigits: 2 })}
                    </td>
                    <td style="text-align:right; font-weight:500;">
                        ${item.balance.toLocaleString('th-TH', { minimumFractionDigits: 2 })}
                    </td>
                </tr>`;
            });
        } else {
            html = '<tr><td colspan="5" class="empty-row" style="padding:16px;">ยังไม่มีรายการ</td></tr>';
        }
        document.getElementById('savingsHistoryBody').innerHTML = html;
    });
}

function saveSavings() {
    const data = {
        MemberId: parseInt(document.getElementById('savingsMemberId').value),
        Amount:   parseFloat(document.getElementById('savingsAmount').value),
        Type:     document.getElementById('transType').value
