async function exportExcel() {
    Swal.fire({ title: 'กำลังเตรียมข้อมูล...', didOpen: () => Swal.showLoading() });
    
    try {
        if (!window.XLSX) {
            await new Promise((resolve, reject) => {
                const s = document.createElement('script');
                s.src = 'https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js';
                s.onload = resolve;
                s.onerror = reject;
                document.head.appendChild(s);
            });
        }

        const res  = await fetch('/Member/GetExportData');
        const data = await res.json();

        const wb = XLSX.utils.book_new();
        const ws = XLSX.utils.json_to_sheet(data);

        const colWidths = Object.keys(data[0] || {}).map(k => ({
            wch: Math.max(k.length, ...data.map(r => String(r[k] ?? '').length)) + 2
        }));
        ws['!cols'] = colWidths;

        XLSX.utils.book_append_sheet(wb, ws, 'สมาชิก');
        
        const today = new Date().toLocaleDateString('th-TH').replace(/\//g, '-');
        XLSX.writeFile(wb, `POOC_สมาชิก_${today}.xlsx`);
        
        Swal.fire('สำเร็จ', 'ดาวน์โหลด Excel เรียบร้อย', 'success');
    } catch(e) {
        Swal.fire('ผิดพลาด', 'Export ไม่สำเร็จ: ' + e.message, 'error');
    }
}
