# ใช้ .NET SDK สำหรับ Build
FROM mcr.microsoft.com/dotnet/sdk:7.0 AS build
WORKDIR /app

# Copy ไฟล์โปรเจกต์และ Restore
COPY *.csproj ./
RUN dotnet restore

# Copy ไฟล์ทั้งหมดและ Build
COPY . ./
RUN dotnet publish -c Release -o out

# ใช้ Runtime สำหรับรันเว็บ
FROM mcr.microsoft.com/dotnet/aspnet:7.0
WORKDIR /app
COPY --from=build /app/out .

# ตั้งค่า Port (Railway/Render จะส่ง Port มาทาง Environment Variable)
ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080

ENTRYPOINT ["dotnet", "POOC.dll"]